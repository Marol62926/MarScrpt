name: ColorWidget
desc: v3.1.1

http:
  mitm:
    - "api.revenuecat.com"
  script:
    - match: ^https?:\/\/api\.revenuecat\.com\/v1\/receipts
      name: ColorWidget
      type: response
      require-body: true
      timeout: 10
      
script-providers:
  ColorWidget:
    url: https://raw.githubusercontent.com/Marol62926/MarScrpt/main/test2.js
    interval:  86400
